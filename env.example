# ── LLM Providers ─────────────────────────────────────────────────────────────
# Required for OpenAI provider (gpt-4o-mini, gpt-4o, gpt-3.5-turbo)
OPENAI_API_KEY=sk-...

# Required for HuggingFace provider (Mistral-7B-Instruct, etc.)
HF_TOKEN=hf_...

# ── Web Search (optional) ──────────────────────────────────────────────────────
# Get a free key at https://tavily.com
# If omitted, the web_search tool will be disabled
TAVILY_API_KEY=tvly-...

# ── Vector DB ─────────────────────────────────────────────────────────────────
# Set by docker-compose automatically; override here for external Qdrant
# QDRANT_URL=http://localhost:6333
